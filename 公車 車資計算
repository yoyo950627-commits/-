<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<title>計程車車資計算器</title>
</head>
<body>

<h2>計程車車資計算器</h2>

搭乘公里數：
<input id="km"><br><br>

<button onclick="calc()">計算車資</button>

<h3 id="result">車資：0 元</h3>

<script>
function calc(){

let km=parseFloat(document.getElementById('km').value)||0;

let fare=0;

if(km>0){
fare=85+(Math.ceil(km)-1)*20;
}

document.getElementById('result').innerHTML=
'車資：'+fare+' 元';

}
</script>

</body>
</html>
